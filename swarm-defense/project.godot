; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SwarmDefense"
run/main_scene="res://scenes/core/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/globals/game_manager.gd"
NetworkManager="*res://scripts/globals/network_manager.gd"
EconomyManager="*res://scripts/globals/economy_manager.gd"
TechManager="*res://scripts/globals/tech_manager.gd"
WaveManager="*res://scripts/globals/wave_manager.gd"
TimeManager="*res://scripts/globals/time_manager.gd"
InputHandler="*res://scripts/globals/input_handler.gd"
AudioManager="*res://scripts/globals/audio_manager.gd"
DebugConsole="*res://scripts/globals/debug_console.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

